<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>পরীক্ষার্থী লগইন</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="login-container">
        <h2>অনলাইন মেধা পরীক্ষা</h2>
        <p>পরীক্ষায় অংশ নিতে আপনার নাম ও নম্বর দিন</p>
        <form action="/login" method="POST">
            <div class="form-group">
                <label>শিক্ষার্থীর নাম:</label>
                <input type="text" name="name" required placeholder="আপনার নাম লিখুন">
            </div>
            <div class="form-group">
                <label>মোবাইল নম্বর:</label>
                <input type="text" name="phone" required placeholder="01XXXXXXXXX">
            </div>
            <button type="submit" class="btn-start">পরীক্ষা শুরু করুন</button>
        </form>
    </div>
</body>
</html>
